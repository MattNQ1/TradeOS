# Supabase project credentials.
# Get these from: Supabase dashboard → your project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server-only: enables admin operations like account deletion + webhook DB writes.
# DO NOT prefix with NEXT_PUBLIC_ — never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Production URL for redirects (Stripe success/cancel, password reset emails, etc.).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Stripe ----------
# Get keys at: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_..., pk_test_...) for development.
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET

# Price IDs from your Stripe products. Create these in dashboard:
#   1. Pro — recurring monthly $19
#   2. Lifetime — one-time payment $199
# Copy the Price IDs (price_xxxxxxxxxxxx) here.
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PRICE_ID
NEXT_PUBLIC_STRIPE_LIFETIME_PRICE_ID=price_YOUR_LIFETIME_PRICE_ID
